 SELECT OBJECT_SCHEMA_NAME (object_id) AS schema_name, name AS procedure_name 
FROM sys.procedures WHERE OBJECT_DEFINITION (object_id) LIKE '%FeeCollectionAdjustment%";


 

3-

SELECT
t.name AS TableName,
STRING AGG(c.name, ', ') AS Columns
FROM sys.tables t
INNER JOIN sys.columns c ON t.object_id = c.object_id
WHERE t.name LIKE '%Fee%"
GROUP BY t.name
ORDER BY t.name;

4—


Select
s.name AS SchemaName,
 t.name AS TableName, 
c.name AS ColumnName,
 ty.name AS DataType
 FROM sys.schemas s
JOIN sys.tables t ON s.schema_id = t.schema_id
JOIN sys.columns c ON t.object_id = c.object_id
JOIN sys.types ty ON c.user_type_id = ty.user_type_id
WHERE t.name LIKE '%Fee%'
ORDER BY s.name, t.name, c.column_id;







